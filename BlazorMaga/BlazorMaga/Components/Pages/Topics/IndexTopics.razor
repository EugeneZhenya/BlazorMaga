@page "/topics/{TopicId:int}"
@page "/topics/{TopicId:int}/{TopicTitle}"
@rendermode InteractiveServer
@inject NavigationManager navigationManager

<PageTitle>@TopicTitle</PageTitle>

<section class="page_title ds s-overlay s-parallax s-pt-130 s-pt-xl-150 s-pb-65">
	<div class="container">
		<div class="row">

			<div class="col-md-12">
				<h1>@TopicTitle</h1>
				<ol class="breadcrumb">
					<li class="breadcrumb-item">
						<a href="/">Початок</a>
					</li>
					<li class="breadcrumb-item">
						<a href="#">Меню</a>
					</li>
					<li class="breadcrumb-item active">
						@TopicTitle
					</li>
				</ol>
			</div>
		</div>
	</div>
</section>

