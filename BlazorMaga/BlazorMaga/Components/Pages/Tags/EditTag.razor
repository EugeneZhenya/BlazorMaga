@page "/tags/edit/{TagId:int}"
@rendermode InteractiveServer

<PageTitle>Редагування позначки</PageTitle>

<section class="ds s-py-90 s-py-xl-150">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h3 class="text-center mt-0 mb-2 special-heading fs-60 color-main">
                    <span>Редагування позначки</span>
                </h3>
                <div class="line"></div>
                <p class="text-center fs-20 mt-4">
                    <span>Внесіть зміни до форми аби відредагувати цю позначку.</span>
                </p>
                <div class="divider-50 divider-xl-60"></div>
            </div>
            <div class="col-12">
                @if (tag != null)
                {
                    <TagForm Tag="tag" OnValidSubmit="Edit" />
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter] public int TagId { get; set; }
    public Tag tag;

    protected override void OnInitialized()
    {
        tag = new Tag
        {
            Id = TagId,
            Mark = $"Позначка {TagId}"
        };
    }

    private void Edit()
    {
        Console.OutputEncoding = System.Text.Encoding.UTF8;
        Console.WriteLine("Edit method");
        Console.WriteLine($"Id = {tag.Id}");
        Console.WriteLine($"Mark = {tag.Mark}");
    }
}
